generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  authUserId         String          @unique @map("auth_user_id")
  email              String          @unique
  name               String
  role               Role            @default(staff)
  branchId           String          @map("branch_id")
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  cashSessions       CashSession[]
  purchases          Purchase[]
  approvedTransfers  StockTransfer[] @relation("ApprovedBy")
  initiatedTransfers StockTransfer[] @relation("InitiatedBy")
  transactions       Transaction[]
  branch             Branch          @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("users")
}

model Branch {
  id            String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  name          String          @unique
  code          String          @unique
  address       String?
  phone         String?
  taxId         String?         @map("tax_id")
  companyName   String?         @map("company_name")
  receiptHeader String?         @map("receipt_header")
  receiptFooter String?         @map("receipt_footer")
  logoUrl       String?         @map("logo_url")
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  cashSessions  CashSession[]
  costLayers    CostLayer[]
  inventory     Inventory[]
  prescriptions Prescription[]
  purchases     Purchase[]
  transfersFrom StockTransfer[] @relation("TransferFrom")
  transfersTo   StockTransfer[] @relation("TransferTo")
  transactions  Transaction[]
  users         User[]

  @@map("branches")
}

model Product {
  id               String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  name             String
  strainType       StrainType?       @map("strain_type")
  sku              String            @unique
  priceTHB         Decimal           @map("price_thb") @db.Decimal(10, 2)
  pricePerGram     Decimal?          @map("price_per_gram") @db.Decimal(10, 2)
  costTHB          Decimal?          @map("cost_thb") @db.Decimal(10, 2)
  costPerGram      Decimal?          @map("cost_per_gram") @db.Decimal(10, 2)
  costVatIncluded  Boolean           @default(true) @map("cost_vat_included")
  soldByWeight     Boolean           @default(false) @map("sold_by_weight")
  description      String?
  thcPercentage    Decimal?          @map("thc_percentage") @db.Decimal(5, 2)
  cbdPercentage    Decimal?          @map("cbd_percentage") @db.Decimal(5, 2)
  expiryDate       DateTime?         @map("expiry_date") @db.Date
  batchNumber      String?           @map("batch_number")
  weightPerUnit    Decimal?          @map("weight_per_unit_grams") @db.Decimal(10, 3)
  categoryId       String?           @map("category_id")
  supplierId       String?           @map("supplier_id")
  zohoItemId       String?           @map("zoho_item_id")
  imageUrl         String?           @map("image_url")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  costLayers       CostLayer[]
  inventory        Inventory[]
  category         Category?         @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  supplier         Supplier?         @relation(fields: [supplierId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  purchaseItems    PurchaseItem[]
  stockAdjustments StockAdjustment[]
  stockTransfers   StockTransfer[]
  transactionItems TransactionItem[]

  @@map("products")
}

model Category {
  id           String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  name         String    @unique
  soldByWeight Boolean   @default(false) @map("sold_by_weight")
  products     Product[]

  @@map("categories")
}

model Supplier {
  id          String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  name        String
  licenseNo   String?    @map("license_no")
  contactName String?    @map("contact_name")
  phone       String?
  email       String?
  address     String?
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  products    Product[]
  purchases   Purchase[]

  @@map("suppliers")
}

model Inventory {
  id        String  @id @default(dbgenerated("(gen_random_uuid())::text"))
  productId String  @map("product_id")
  branchId  String  @map("branch_id")
  quantity  Decimal @db.Decimal(10, 3)
  room      String  @default("Shelf")
  branch    Branch  @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product   Product @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([productId, branchId])
  @@map("inventory")
}

model StockAdjustment {
  id        String                @id @default(dbgenerated("(gen_random_uuid())::text"))
  productId String                @map("product_id")
  branchId  String                @map("branch_id")
  quantity  Decimal               @db.Decimal(10, 3)
  reason    StockAdjustmentReason
  notes     String?
  userId    String                @map("user_id")
  createdAt DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  product   Product               @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("stock_adjustments")
}

model CostLayer {
  id                String                 @id @default(dbgenerated("(gen_random_uuid())::text"))
  productId         String                 @map("product_id")
  branchId          String                 @map("branch_id")
  purchaseItemId    String?                @map("purchase_item_id")
  quantityInitial   Decimal                @map("quantity_initial") @db.Decimal(10, 3)
  quantityRemaining Decimal                @map("quantity_remaining") @db.Decimal(10, 3)
  unitCostTHB       Decimal                @map("unit_cost_thb") @db.Decimal(10, 2)
  receivedAt        DateTime               @map("received_at") @db.Timestamptz(6)
  batchNumber       String?                @map("batch_number")
  createdAt         DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  consumptions      CostLayerConsumption[]
  branch            Branch                 @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product           Product                @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  purchaseItem      PurchaseItem?          @relation(fields: [purchaseItemId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([productId, branchId, receivedAt], map: "idx_cost_layers_product_branch_received")
  @@map("cost_layers")
}

model CostLayerConsumption {
  id                String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  costLayerId       String          @map("cost_layer_id")
  transactionItemId String          @map("transaction_item_id")
  quantity          Decimal         @db.Decimal(10, 3)
  unitCostTHB       Decimal         @map("unit_cost_thb") @db.Decimal(10, 2)
  totalCostTHB      Decimal         @map("total_cost_thb") @db.Decimal(10, 2)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  costLayer         CostLayer       @relation(fields: [costLayerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transactionItem   TransactionItem @relation(fields: [transactionItemId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("cost_layer_consumptions")
}

model Purchase {
  id            String         @id @default(dbgenerated("(gen_random_uuid())::text"))
  supplierId    String         @map("supplier_id")
  branchId      String         @map("branch_id")
  invoiceNumber String?        @map("invoice_number")
  subtotalTHB   Decimal        @map("subtotal_thb") @db.Decimal(10, 2)
  vatRate       Decimal        @default(7.00) @map("vat_rate") @db.Decimal(5, 2)
  vatTHB        Decimal        @map("vat_thb") @db.Decimal(10, 2)
  totalTHB      Decimal        @map("total_thb") @db.Decimal(10, 2)
  vatIncluded   Boolean        @default(true) @map("vat_included")
  status        PurchaseStatus @default(draft)
  notes         String?
  purchaseDate  DateTime       @default(now()) @map("purchase_date") @db.Timestamptz(6)
  userId        String         @map("user_id")
  zohoPOId      String?        @map("zoho_po_id")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  items         PurchaseItem[]
  branch        Branch         @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  supplier      Supplier       @relation(fields: [supplierId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user          User           @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("purchases")
}

model PurchaseItem {
  id          String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  purchaseId  String      @map("purchase_id")
  productId   String      @map("product_id")
  quantity    Decimal     @db.Decimal(10, 3)
  unitCostTHB Decimal     @map("unit_cost_thb") @db.Decimal(10, 2)
  subtotalTHB Decimal     @map("subtotal_thb") @db.Decimal(10, 2)
  vatTHB      Decimal     @map("vat_thb") @db.Decimal(10, 2)
  totalTHB    Decimal     @map("item_total_thb") @db.Decimal(10, 2)
  weightGrams Decimal?    @map("weight_grams") @db.Decimal(10, 3)
  expiryDate  DateTime?   @map("expiry_date") @db.Date
  batchNumber String?     @map("batch_number")
  costLayers  CostLayer[]
  product     Product     @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  purchase    Purchase    @relation(fields: [purchaseId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("purchase_items")
}

model Customer {
  id            String         @id @default(dbgenerated("(gen_random_uuid())::text"))
  idNumber      String         @map("id_number")
  idType        IdType         @map("id_type")
  name          String?
  dateOfBirth   DateTime       @map("date_of_birth") @db.Date
  nationality   String?
  phone         String?
  email         String?
  notes         String?
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  prescriptions Prescription[]
  transactions  Transaction[]

  @@unique([idNumber, idType])
  @@map("customers")
}

model Prescription {
  id                       String                    @id @default(dbgenerated("(gen_random_uuid())::text"))
  customerId               String                    @map("customer_id")
  prescriptionNo           String                    @unique @map("prescription_no")
  prescriberId             String?                   @map("prescriber_id")
  issuedDate               DateTime                  @map("issued_date") @db.Date
  expiryDate               DateTime                  @map("expiry_date") @db.Date
  dailyDosageG             Decimal?                  @map("daily_dosage_grams") @db.Decimal(5, 2)
  numDays                  Int?                      @map("num_days")
  totalAllowedG            Decimal?                  @map("total_allowed_grams") @db.Decimal(8, 2)
  consumedG                Decimal                   @default(0) @map("consumed_grams") @db.Decimal(8, 2)
  diagnosis                String?
  documentUrl              String?                   @map("document_url")
  pt33PdfUrl               String?                   @map("pt33_pdf_url")
  createdInPos             Boolean                   @default(false) @map("created_in_pos")
  branchId                 String                    @map("branch_id")
  notes                    String?
  createdAt                DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  branch                   Branch                    @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customer                 Customer                  @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  prescriber               Prescriber?               @relation(fields: [prescriberId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transactionPrescriptions TransactionPrescription[]

  @@map("prescriptions")
}

model Prescriber {
  id             String         @id @default(dbgenerated("(gen_random_uuid())::text"))
  name           String
  licenseNo      String         @unique @map("license_no")
  licenseType    String?        @map("license_type")
  professionType ProfessionType @map("profession_type")
  address        String?
  phone          String?
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  prescriptions  Prescription[]

  @@map("prescribers")
}

model Transaction {
  id            String                    @id @default(dbgenerated("(gen_random_uuid())::text"))
  customerId    String                    @map("customer_id")
  userId        String                    @map("user_id")
  branchId      String                    @map("branch_id")
  subtotalTHB   Decimal                   @map("subtotal_thb") @db.Decimal(10, 2)
  vatRate       Decimal                   @default(7.00) @map("vat_rate") @db.Decimal(5, 2)
  vatTHB        Decimal                   @map("vat_thb") @db.Decimal(10, 2)
  totalTHB      Decimal                   @map("total_thb") @db.Decimal(10, 2)
  vatIncluded   Boolean                   @default(true) @map("vat_included")
  discountType  String?                   @map("discount_type")
  discountValue Decimal?                  @map("discount_value") @db.Decimal(10, 2)
  discountTHB   Decimal?                  @map("discount_thb") @db.Decimal(10, 2)
  status        TransactionStatus         @default(completed)
  paymentMethod PaymentMethod             @map("payment_method")
  reportType    ReportType                @default(sell) @map("report_type")
  receiptNumber String                    @unique @map("receipt_number")
  ageVerified   Boolean                   @default(false) @map("age_verified")
  customerAge   Int?                      @map("customer_age")
  createdAt     DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  items         TransactionItem[]
  prescriptions TransactionPrescription[]
  branch        Branch                    @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customer      Customer                  @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user          User                      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("transactions")
}

model TransactionItem {
  id               String                 @id @default(dbgenerated("(gen_random_uuid())::text"))
  transactionId    String                 @map("transaction_id")
  productId        String                 @map("product_id")
  quantity         Decimal                @db.Decimal(10, 3)
  unitPriceTHB     Decimal                @map("unit_price_thb") @db.Decimal(10, 2)
  subtotalTHB      Decimal                @map("subtotal_thb") @db.Decimal(10, 2)
  vatTHB           Decimal                @map("vat_thb") @db.Decimal(10, 2)
  totalTHB         Decimal                @map("item_total_thb") @db.Decimal(10, 2)
  weightGrams      Decimal?               @map("weight_grams") @db.Decimal(10, 3)
  pricePerGram     Decimal?               @map("price_per_gram") @db.Decimal(10, 2)
  scaleReading     Decimal?               @map("scale_reading") @db.Decimal(10, 3)
  cogsTHB          Decimal                @default(0) @map("cogs_thb") @db.Decimal(10, 2)
  costConsumptions CostLayerConsumption[]
  product          Product                @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transaction      Transaction            @relation(fields: [transactionId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("transaction_items")
}

model TransactionPrescription {
  transactionId  String       @map("transaction_id")
  prescriptionId String       @map("prescription_id")
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transaction    Transaction  @relation(fields: [transactionId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([transactionId, prescriptionId])
  @@map("transaction_prescriptions")
}

model CashSession {
  id           String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId       String    @map("user_id")
  branchId     String    @map("branch_id")
  deviceName   String?   @map("device_name")
  openingFloat Decimal   @map("opening_float") @db.Decimal(10, 2)
  closingFloat Decimal?  @map("closing_float") @db.Decimal(10, 2)
  expectedCash Decimal?  @map("expected_cash") @db.Decimal(10, 2)
  actualCash   Decimal?  @map("actual_cash") @db.Decimal(10, 2)
  discrepancy  Decimal?  @db.Decimal(10, 2)
  openedAt     DateTime  @default(now()) @map("opened_at") @db.Timestamptz(6)
  closedAt     DateTime? @map("closed_at") @db.Timestamptz(6)
  branch       Branch    @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user         User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("cash_sessions")
}

model StockTransfer {
  id            String         @id @default(dbgenerated("(gen_random_uuid())::text"))
  fromBranchId  String         @map("from_branch_id")
  toBranchId    String         @map("to_branch_id")
  productId     String         @map("product_id")
  quantity      Decimal        @db.Decimal(10, 3)
  weightGrams   Decimal?       @map("weight_grams") @db.Decimal(10, 3)
  status        TransferStatus @default(requested)
  initiatedById String         @map("initiated_by")
  approvedById  String?        @map("approved_by")
  notes         String?
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt   DateTime?      @map("completed_at") @db.Timestamptz(6)
  approvedBy    User?          @relation("ApprovedBy", fields: [approvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fromBranch    Branch         @relation("TransferFrom", fields: [fromBranchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  initiatedBy   User           @relation("InitiatedBy", fields: [initiatedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product       Product        @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  toBranch      Branch         @relation("TransferTo", fields: [toBranchId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("stock_transfers")
}

model ZohoSyncLog {
  id         String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  entityType String        @map("entity_type")
  entityId   String        @map("entity_id")
  direction  SyncDirection
  status     SyncStatus
  errorMsg   String?       @map("error_msg")
  syncedAt   DateTime      @default(now()) @map("synced_at") @db.Timestamptz(6)

  @@map("zoho_sync_log")
}

model BankTransaction {
  id                String                @id @default(dbgenerated("(gen_random_uuid())::text"))
  zohoTransactionId String                @unique @map("zoho_transaction_id")
  date              DateTime              @db.Date
  description       String
  amountTHB         Decimal               @map("amount_thb") @db.Decimal(12, 2)
  type              String
  reconciled        Boolean               @default(false)
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  matches           ReconciliationMatch[]

  @@map("bank_transactions")
}

model ReconciliationMatch {
  id                String               @id @default(dbgenerated("(gen_random_uuid())::text"))
  bankTransactionId String               @map("bank_transaction_id")
  invoiceId         String               @map("invoice_id")
  confidenceScore   Decimal              @map("confidence_score") @db.Decimal(4, 3)
  status            ReconciliationStatus @default(pending_review)
  aiReasoning       String?              @map("ai_reasoning")
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  bankTransaction   BankTransaction      @relation(fields: [bankTransactionId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("reconciliation_matches")
}

enum Role {
  admin
  manager
  staff
}

enum IdType {
  national_id
  passport
}

enum StrainType {
  indica
  sativa
  hybrid
}

enum TransactionStatus {
  completed
  voided
  refunded
}

enum PaymentMethod {
  cash
  card
  transfer
}

enum SyncDirection {
  push
  pull
}

enum SyncStatus {
  success
  error
  pending
}

enum ReconciliationStatus {
  pending_review
  accepted
  rejected
  auto_matched
}

enum TransferStatus {
  requested
  approved
  dispatched
  received
  confirmed
  cancelled
}

enum ReportType {
  self_use
  sell
  research
  process
  export_abroad
}

enum StockAdjustmentReason {
  received
  damaged
  correction
  waste
  transfer_out
  transfer_in
}

enum PurchaseStatus {
  draft
  confirmed
  received
  cancelled
}

enum ProfessionType {
  medical
  thai_traditional
  thai_applied
  dental
  pharmacy
  chinese_medicine
  folk_healer
}
